{
  "name": "airstream",
  "version": "1.0.0",
  "description": "WiFi Audio Streamer - Stream Windows system audio to iOS Safari/AirPods",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "devices": "node server/utils/device-list.js",
    "build": "pkg server/index.js --targets node18-win-x64 --output dist/airstream.exe"
  },
  "pkg": {
    "scripts": [
      "server/**/*.js"
    ]
  },
  "keywords": [
    "audio",
    "streaming",
    "websocket",
    "airpods",
    "wifi"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.13.1"
  }
}
